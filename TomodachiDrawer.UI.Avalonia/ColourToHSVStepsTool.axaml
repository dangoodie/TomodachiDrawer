<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="TomodachiDrawer.UI.Avalonia.ColourToHSVStepsTool"
        Icon="/Assets/Icon.png"
        Title="Colour to HSV Steps Tool"
        Width="300" Height="205"
        CanResize="False"
		WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key='Light'>
                    <SolidColorBrush x:Key='TextBoxDisabledBackground'>#DEDEDE</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key='Dark'>
                    <SolidColorBrush x:Key='TextBoxDisabledBackground'>#151515</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
	</Window.Resources>
    <Window.Styles>
        <Style Selector="Grid.field">
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="ColumnSpacing" Value="5" />
        </Style>
        <Style Selector="Grid.field > TextBlock">
            <Setter Property="TextAlignment" Value="Right" />
        </Style>
        <Style Selector="Grid.field TextBlock">
            <!-- For the TextBox's InnerRightContent -->
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="Grid.field TextBox[IsReadOnly=True]">
            <Setter Property="Background" Value="{DynamicResource TextBoxDisabledBackground}"></Setter>
        </Style>
    </Window.Styles>
    <StackPanel Margin="8">
        <Grid Classes="field"
              ColumnDefinitions="75,*">
            <TextBlock Text="RGB Hex:" />
            <TextBox x:Name="ColourHex"
                     Grid.Column="1"
                     PlaceholderText="#RRGGBB"
                     TextChanged="ColourHex_TextChanged" />
        </Grid>

        <Separator Margin="0,10" />

        <Grid Classes="field" ColumnDefinitions="75,*">
            <TextBlock Text="Hue:" />
            <TextBox x:Name="HueStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>

        <Grid Classes="field" ColumnDefinitions="75,*">
            <TextBlock Text="Saturation:" />
            <TextBox x:Name="SatStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>

        <Grid Classes="field" ColumnDefinitions="75,*">
            <TextBlock Text="Value:" />
            <TextBox x:Name="ValStepsOutput"
                     Grid.Column="1"
                     IsReadOnly="True" />
        </Grid>
    </StackPanel>
</Window>
